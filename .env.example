SHOPIFY_STORE=holo-vault-3.myshopify.com

# Dev Dashboard app (recommended — token auto-refreshes every ~24h)
SHOPIFY_CLIENT_ID=your_client_id
SHOPIFY_CLIENT_SECRET=your_client_secret

# Optional fallback: static Admin API token (expires ~24h on Dev Dashboard apps)
# SHOPIFY_TOKEN=shpat_your_admin_api_token

SHOPIFY_API_VERSION=2024-04
# Optional: ms between Shopify API calls (default 550 ≈ under 2/sec limit)
# SHOPIFY_API_GAP_MS=550

DEFAULT_MULTIPLIER=1.0
CRON_SCHEDULE=0 6 * * *
PORT=3000
